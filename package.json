{
  "name": "sentriscloud-frontend",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for SentrisCloud user-facing products (explorer, wallet, faucet, exchange, landing).",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "playwright": "^1.59.1",
    "turbo": "^2.10.0",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "19",
        "react-dom": "19"
      }
    },
    "overrides": {
      "porto>zod": "^4.4.2",
      "wagmi": "2.19.5",
      "axios": "^1.15.2"
    }
  }
}
