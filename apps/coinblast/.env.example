# CoinBlast — public runtime env. Copy to `.env.production` for prod
# builds (`.env*` is gitignored). All NEXT_PUBLIC_ values are baked into
# the client bundle at build time, so changes require a rebuild.

NEXT_PUBLIC_API_URL=https://api.sentrixchain.com
NEXT_PUBLIC_RPC_URL=https://rpc.sentrixchain.com/rpc
NEXT_PUBLIC_EXPLORER_URL=https://scan.sentrixchain.com
NEXT_PUBLIC_CHAIN_ID=7119
