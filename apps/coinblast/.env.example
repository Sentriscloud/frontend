# CoinBlast — public runtime env. Copy to `.env.production` for prod
# builds (`.env*` is gitignored). All NEXT_PUBLIC_ values are baked into
# the client bundle at build time, so changes require a rebuild.

NEXT_PUBLIC_API_URL=https://api.sentrixchain.com
NEXT_PUBLIC_RPC_URL=https://rpc.sentrixchain.com/rpc
NEXT_PUBLIC_EXPLORER_URL=https://scan.sentrixchain.com
NEXT_PUBLIC_CHAIN_ID=7119

# Pinata IPFS pinning — server-side proxy in /api/pin. JWT goes into
# .env.production.local (gitignored), NEVER into a NEXT_PUBLIC_* var
# (those bake into the browser bundle). Mint at pinata.cloud → API Keys
# with `pinFileToIPFS` scope.
PINATA_JWT=

# Public IPFS gateway the browser uses to resolve ipfs://<cid> URLs.
# Defaults to gateway.pinata.cloud — override to a custom-subdomain
# Pinata gateway later if shared-gateway rate limits bite.
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/
