# Sentrix Faucet — environment template.
#
# Copy to `.env.production` and fill in the PLACEHOLDERs. Both REST_URL
# values default to the public Sentrix endpoints — only swap in a
# loopback URL when the build runs on the same host as the validator
# process and you understand the trust implications.

# ── Public (shared across networks) ─────────────────────────────────
NEXT_PUBLIC_EXPLORER_URL=https://scan.sentrixchain.com
NEXT_PUBLIC_DOCS_URL=https://sentrixchain.com/docs/faucet

# ── Testnet (chain ID 7120) ─────────────────────────────────────────
TESTNET_REST_URL=https://testnet-api.sentrixchain.com
TESTNET_FAUCET_ADDRESS=PLACEHOLDER
TESTNET_FAUCET_PRIVATE_KEY=PLACEHOLDER
TESTNET_DRIP_AMOUNT_SRX=10
TESTNET_FEE_SENTRI=10000
# Optional Turnstile on testnet (usually skip):
# NEXT_PUBLIC_TESTNET_TURNSTILE_SITE_KEY=
# TESTNET_TURNSTILE_SECRET_KEY=

# ── Mainnet (chain ID 7119) ─────────────────────────────────────────
MAINNET_REST_URL=https://api.sentrixchain.com
MAINNET_FAUCET_ADDRESS=PLACEHOLDER
MAINNET_FAUCET_PRIVATE_KEY=PLACEHOLDER
MAINNET_DRIP_AMOUNT_SRX=0.01
MAINNET_FEE_SENTRI=10000
# REQUIRED on mainnet — otherwise mainnet POST will fail (no anti-abuse):
# NEXT_PUBLIC_MAINNET_TURNSTILE_SITE_KEY=
# MAINNET_TURNSTILE_SECRET_KEY=

# ── Rate-limit persistence ──────────────────────────────────────────
# REQUIRED in production. The rate-limit store tracks per-IP and
# per-address cooldowns + the cumulative totalDistributed counter.
# Defaults to os.tmpdir()/faucet-limits.json which on Linux is /tmp —
# WIPED ON EVERY HOST REBOOT. That means rate-limit cooldowns reset on
# reboot (faucet-drain risk) and the totalDistributed counter resets to
# zero. Always point this at a persistent path under /var/lib or
# /home/<svc-user>/state owned by the faucet service user with mode 640.
RATE_LIMIT_FILE=/var/lib/sentrix-faucet/limits.json
