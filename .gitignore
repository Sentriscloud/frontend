# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
.next/
out/
coverage/

# Turborepo
.turbo/

# Editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp
*.swo

# Env — never commit any of these. Per-app gitignores cover most apps
# but the root entry is the safety net for any new app added without
# its own .gitignore.
.env
.env.local
.env.*.local
.env.production
.env.production.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Misc
*.tsbuildinfo
